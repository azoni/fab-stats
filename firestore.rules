rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function adminConfig() {
      return get(/databases/$(database)/documents/admin/config).data;
    }

    function adminEmails() {
      return ('adminEmails' in adminConfig() && adminConfig().adminEmails is list)
        ? adminConfig().adminEmails
        : [];
    }

    function adminUids() {
      return ('adminUids' in adminConfig() && adminConfig().adminUids is list)
        ? adminConfig().adminUids
        : [];
    }

    // Helper: check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || (request.auth.token.email != null && request.auth.token.email in adminEmails())
          || (request.auth.uid != null && request.auth.uid in adminUids())
        );
    }

    // Helper: string length check (for text fields)
    function maxLen(field, len) {
      return field is string && field.size() <= len;
    }

    // Profile background catalog validation guards
    function validBackgroundKind(kind) {
      return kind in ["key-art", "playmat", "hero-art"];
    }

    function validBackgroundUnlockType(unlockType) {
      return unlockType in ["achievement", "supporter", "manual"];
    }

    function validBackgroundStorageUrl(url, folder) {
      return url is string
        && url.size() <= 600
        && (
          url.matches('^https://firebasestorage.googleapis.com/v0/b/[^/]+/o/profile-backgrounds%2F' + folder + '%2F[A-Za-z0-9._-]+\\.(jpg|jpeg|png|webp)\\?alt=media(&token=[A-Za-z0-9._%-]+)?$')
          || url.matches('^/backgrounds/[A-Za-z0-9/_-]+\\.(jpg|jpeg|png|webp)$')
        );
    }

    function validProfileBackgroundCatalogDoc(data, backgroundId) {
      return data.keys().hasOnly([
        'id',
        'label',
        'imageUrl',
        'thumbnailUrl',
        'kind',
        'focusPosition',
        'adminOnly',
        'sortOrder',
        'isActive',
        'unlockType',
        'unlockKey',
        'unlockLabel',
        'updatedAt'
      ])
      && ('id' in data)
      && ('label' in data)
      && ('imageUrl' in data)
      && ('thumbnailUrl' in data)
      && ('kind' in data)
      && data.id is string
      && data.id == backgroundId
      && data.id.size() <= 80
      && maxLen(data.label, 80)
      && validBackgroundKind(data.kind)
      && validBackgroundStorageUrl(data.imageUrl, 'full')
      && validBackgroundStorageUrl(data.thumbnailUrl, 'thumb')
      && (!('focusPosition' in data) || maxLen(data.focusPosition, 40))
      && (!('adminOnly' in data) || data.adminOnly is bool)
      && (!('sortOrder' in data) || (data.sortOrder is int && data.sortOrder >= 0 && data.sortOrder <= 100000))
      && (!('isActive' in data) || data.isActive is bool)
      && (!('unlockType' in data) || validBackgroundUnlockType(data.unlockType))
      && (!('unlockKey' in data) || maxLen(data.unlockKey, 120))
      && (!('unlockLabel' in data) || maxLen(data.unlockLabel, 120))
      && (!('unlockType' in data) || ('unlockKey' in data))
      && (!('updatedAt' in data) || maxLen(data.updatedAt, 40));
    }

    // ── User profiles ──
    match /users/{userId}/profile/{docId} {
      // Owner can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Authenticated users can read public profiles
      allow read: if resource.data.isPublic == true
        && (request.auth != null || resource.data.get('hideFromGuests', false) == false);
      // Admin can read all profiles
      allow read: if isAdmin();
    }

    // ── Match records ──
    match /users/{userId}/matches/{matchId} {
      // Owner can read their own matches
      allow read: if request.auth != null && request.auth.uid == userId;
      // Owner can create/update/delete with field length limits
      allow create: if request.auth != null && request.auth.uid == userId
        && (!("notes" in request.resource.data) || maxLen(request.resource.data.notes, 2000))
        && (!("matchNotes" in request.resource.data) || maxLen(request.resource.data.matchNotes, 2000))
        && (!("opponentName" in request.resource.data) || maxLen(request.resource.data.opponentName, 100))
        && (!("venue" in request.resource.data) || maxLen(request.resource.data.venue, 200))
        && (!("eventType" in request.resource.data) || maxLen(request.resource.data.eventType, 50))
        && (!("winCondition" in request.resource.data) || maxLen(request.resource.data.winCondition, 20))
        && (!("goingFirst" in request.resource.data) || request.resource.data.goingFirst is bool);
      allow update: if request.auth != null && request.auth.uid == userId
        && (!("notes" in request.resource.data) || maxLen(request.resource.data.notes, 2000))
        && (!("matchNotes" in request.resource.data) || maxLen(request.resource.data.matchNotes, 2000))
        && (!("opponentName" in request.resource.data) || maxLen(request.resource.data.opponentName, 100))
        && (!("venue" in request.resource.data) || maxLen(request.resource.data.venue, 200))
        && (!("eventType" in request.resource.data) || maxLen(request.resource.data.eventType, 50))
        && (!("winCondition" in request.resource.data) || maxLen(request.resource.data.winCondition, 20))
        && (!("goingFirst" in request.resource.data) || request.resource.data.goingFirst is bool);
      allow delete: if request.auth != null && request.auth.uid == userId;
      // Admin can update/delete any user's matches (for data fixes)
      allow update, delete: if isAdmin();
      // Public read: if the user's profile is public (and not hidden from guests)
      allow read: if get(/databases/$(database)/documents/users/$(userId)/profile/main).data.isPublic == true
        && (request.auth != null || get(/databases/$(database)/documents/users/$(userId)/profile/main).data.get('hideFromGuests', false) == false);
      // Admin can read all matches (for aggregate stats)
      allow read: if isAdmin();
      // Any authenticated user can update ONLY commentCount (and must be a valid increment)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        && request.resource.data.commentCount is int
        && request.resource.data.commentCount >= 0;
      // Cross-player match linking: any authenticated user can set opponentHero
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['opponentHero'])
        && request.resource.data.opponentHero is string
        && request.resource.data.opponentHero.size() <= 100;

      // ── Comments on matches ──
      match /comments/{commentId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          get(/databases/$(database)/documents/users/$(userId)/profile/main).data.isPublic == true
        );
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && maxLen(request.resource.data.text, 1000);
        allow update: if request.auth != null
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
          && maxLen(request.resource.data.text, 1000);
        allow delete: if request.auth != null
          && (resource.data.authorUid == request.auth.uid || request.auth.uid == userId);
      }
    }

    // ── Notifications ──
    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && (!("commentPreview" in request.resource.data) || maxLen(request.resource.data.commentPreview, 500))
        && (!("messagePreview" in request.resource.data) || maxLen(request.resource.data.messagePreview, 500));
      // Allow message senders to update their own notifications (for grouping multiple messages)
      allow update: if request.auth != null
        && resource.data.type == "message"
        && resource.data.senderUid == request.auth.uid;
      // Allow kudos giver to delete their kudos notification (when revoking)
      allow delete: if request.auth != null
        && resource.data.type == "kudos"
        && resource.data.kudosGiverUid == request.auth.uid;
    }

    // ── Favorites ──
    match /users/{userId}/favorites/{favoriteId} {
      // Only the owner can read/write their own favorites
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Matchup Notes (private per-hero notes) ──
    match /users/{userId}/matchupNotes/{heroName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Goals (private per-user goal tracking) ──
    match /users/{userId}/goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Username reservations ──
    match /usernames/{username} {
      // Anyone can read (for availability checks, search, profile lookups)
      allow read: if true;
      // Only allow create if userId matches the authenticated user
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      // Owner can update searchable fields (displayName, searchName)
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'searchName']);
      // Owner can delete their own username reservation (account deletion)
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── GEM ID lookup (maps GEM player ID → userId) ──
    match /gemIds/{gemId} {
      // Anyone authenticated can read (needed for cross-player match linking)
      allow read: if request.auth != null;
      // Create/update: only if userId matches the authenticated user
      allow create, update: if request.auth != null
                            && request.resource.data.userId == request.auth.uid;
      // Delete: only the owner
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Shared match comment threads ──
    match /matchThreads/{threadId} {
      // Any authenticated user can read threads
      allow read: if request.auth != null;
      // Create: must include participants array with the creator in it
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.commentCount is int;
      // Only participants can update thread metadata
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Comments within shared threads
      match /comments/{commentId} {
        allow read: if request.auth != null;
        // Create: authorUid must match the authenticated user, text max 1000
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && maxLen(request.resource.data.text, 1000);
        // Update: only the comment author, only text + editedAt
        allow update: if request.auth != null
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
          && maxLen(request.resource.data.text, 1000);
        // Delete: comment author OR any match participant (match owners)
        allow delete: if request.auth != null
          && (resource.data.authorUid == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/matchThreads/$(threadId)).data.participants);
      }
    }

    // ── Event comment walls ──
    match /eventWalls/{eventId}/comments/{commentId} {
      // Authenticated users only (protects commenter names from unauthenticated scraping)
      allow read: if request.auth != null;
      // Create: auth required, authorUid must match, text max 500, not muted
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && maxLen(request.resource.data.text, 500)
        && (!exists(/databases/$(database)/documents/admin/mutedWallUsers)
            || !(request.auth.uid in get(/databases/$(database)/documents/admin/mutedWallUsers).data.userIds));
      // Update: author only (text + editedAt), OR admin can edit any comment
      allow update: if request.auth != null
        && (
          (resource.data.authorUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
            && maxLen(request.resource.data.text, 500))
          || isAdmin()
        );
      // Reactions: any authenticated user can toggle reactions
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      // Delete: author or admin
      allow delete: if request.auth != null
        && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // ── Leaderboard ──
    match /leaderboard/{userId} {
      // Authenticated users can read all entries; guests only see non-hidden entries
      allow read: if request.auth != null
        || resource.data.get('hideFromGuests', false) == false;
      // Only allow owner to write their own entry, or admin
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin())
        // Validate the userId field matches the doc ID (prevent spoofing another user's entry)
        && request.resource.data.userId == userId
        && request.resource.data.totalMatches is int
        && request.resource.data.totalWins is int
        && request.resource.data.totalLosses is int
        && request.resource.data.winRate is number;
    }

    // ── Activity feed ──
    match /feedEvents/{eventId} {
      // Authenticated users only (feed is already hidden from guests in the UI)
      allow read: if request.auth != null;
      // Only public profiles can create feed events
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["import", "achievement", "placement", "fabdoku", "fabdoku-cards", "crossword", "heroguesser", "matchupmania", "trivia", "timeline", "connections", "rampage", "kayosknockout", "brutebrawl", "ninjacombo", "shadowstrike", "bladedash"]
        && request.resource.data.isPublic == true;
      // Reactions: any authenticated user can toggle reactions
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      // Owner or admin can delete feed events
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── AI Chat Messages (server writes via Admin SDK, owner can read + delete) ──
    match /users/{userId}/chatMessages/{messageId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/chatStats/{docId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ── Earned achievements tracking (per user) ──
    match /users/{userId}/earnedAchievements/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/predictions/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Admin writes (granting via prediction-service), user can also read
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // ── Feedback (bug reports / feature requests) ──
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && maxLen(request.resource.data.message, 2000)
        && request.resource.data.type in ["bug", "feature"];
      // Users can read their own feedback; admins can read all + update status
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin();
    }

    // ── Conversations (messaging) ──
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && maxLen(request.resource.data.text, 2000);
      }
    }

    // ── Friendships ──
    match /friendships/{friendshipId} {
      // Participants can read their own friendships; admins can read any
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.participants || isAdmin());
      // Requester can create (status must be "pending", requesterUid must match auth)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.requesterUid
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.status == "pending"
        && request.resource.data.participants.size() == 2;
      // Recipient can update status to "accepted"
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.auth.uid != resource.data.requesterUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt'])
        && request.resource.data.status == "accepted";
      // Either participant can delete (unfriend or decline)
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }

    // ── Analytics (page views, creator clicks) ──
    match /analytics/{docId} {
      allow write: if request.auth != null;
      // Only admins can read analytics data
      allow read: if isAdmin();
    }

    // ── Admin activity log (feature engagement tracking) ──
    match /adminActivity/{activityId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    // ── Admin configuration ──
    // Featured events are public (shown on homepage to all visitors)
    match /admin/featuredEvents {
      allow read: if true;
    }
    // Site banner is public (shown to all visitors)
    match /admin/banner {
      allow read: if true;
    }
    // Badge assignments are public (shown on player profiles to all visitors)
    match /admin/badges {
      allow read: if true;
    }
    // Season definitions are public (shown in meta page dropdowns)
    match /admin/seasons {
      allow read: if true;
    }
    // Poll config is public (shown on homepage); votes are per-user
    match /admin/poll {
      allow read: if true;

      match /votes/{voterId} {
        allow write: if request.auth != null && request.auth.uid == voterId;
        // Any authenticated user can read votes (for viewing poll results)
        allow read: if request.auth != null;
      }
    }
    // Multi-poll collection (replaces single admin/poll document)
    match /polls/{pollId} {
      allow read: if true;
      allow write: if isAdmin();
      // Authenticated users can add options to prediction polls (append-only, max 50, tracks per-user count)
      allow update: if request.auth != null
        && resource.data.type == "prediction"
        && resource.data.allowUserOptions == true
        && resource.data.votingOpen == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options', 'optionAddCount'])
        && request.resource.data.options.size() <= resource.data.options.size() + 1
        && request.resource.data.options.size() <= 50;

      match /votes/{voterId} {
        allow write: if request.auth != null && request.auth.uid == voterId;
        allow read: if request.auth != null;
      }
    }

    // Profile background catalog metadata (image URLs + thumbnail URLs + labels)
    match /profileBackgroundCatalog/{backgroundId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && validProfileBackgroundCatalogDoc(request.resource.data, backgroundId);
      allow delete: if isAdmin();
    }

    // ── Head-to-Head records (precomputed from match data) ──
    match /h2h/{pairId} {
      // Anyone can read (public comparison data)
      allow read: if true;
      // Only participants can write their own H2H records
      allow write: if request.auth != null
        && (request.resource.data.p1 == request.auth.uid
            || request.resource.data.p2 == request.auth.uid);
    }

    // ── Community Hero Matchups (aggregated hero-vs-hero win rates) ──
    match /heroMatchups/{docId} {
      // Public read (community stats)
      allow read: if true;
      // Any authenticated user can write (aggregation runs client-side after import)
      allow write: if request.auth != null;
    }

    // ── Kudos (peer-to-peer endorsements) ──
    // Individual kudos: deterministic doc ID = recipientId_giverId_kudosType
    match /kudos/{kudosId} {
      // Anyone authenticated can read (to check if they've given a kudos)
      allow read: if request.auth != null;
      // Create: giverId must match auth, cannot give to yourself
      allow create: if request.auth != null
        && request.resource.data.giverId == request.auth.uid
        && request.resource.data.recipientId != request.auth.uid
        && request.resource.data.kudosType in ["props", "good_sport", "skilled", "helpful"];
      // Delete: only the giver can revoke
      allow delete: if request.auth != null
        && resource.data.giverId == request.auth.uid;
    }
    // Aggregated kudos counts per recipient
    match /kudosCounts/{recipientId} {
      // Anyone can read (displayed on profiles)
      allow read: if true;
      // Authenticated users can create/update (increment/decrement counters)
      allow create, update: if request.auth != null;
    }
    // Aggregated kudos given counts per giver
    match /kudosGivenCounts/{giverId} {
      // Anyone can read (displayed on profiles and leaderboard)
      allow read: if true;
      // Authenticated users can create/update (increment/decrement counters)
      allow create, update: if request.auth != null;
    }

    // ── FaBdoku (daily hero puzzle game) ──
    // Results: one per user per day
    match /fabdoku-results/{resultId} {
      // Anyone can read (for community stats / leaderboards)
      allow read: if true;
      // Authenticated users can create their own result (uid must match)
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // Owner can update their own result (replays overwrite)
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    // Pick aggregation: atomic increments for uniqueness scoring
    match /fabdoku-picks/{dateStr} {
      // Anyone can read (needed to display uniqueness % after game)
      allow read: if true;
      // Anyone can create or update (anonymous players contribute to uniqueness)
      // Validate: must have totalPlayers (number) and cells (map), doc size stays reasonable
      allow create: if request.resource.data.totalPlayers is int
        && request.resource.data.cells is map
        && request.resource.data.keys().hasOnly(['totalPlayers', 'cells']);
      allow update: if request.resource.data.totalPlayers is int
        && request.resource.data.cells is map
        && request.resource.data.keys().hasOnly(['totalPlayers', 'cells']);
    }
    // Per-user FaBdoku stats (streaks, games played)
    match /users/{userId}/fabdoku-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Public FaBdoku player stats (cross-user readable for profile cards)
    match /fabdokuPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Crossword (daily word puzzle game) ──
    // Results: one per user per day
    match /crossword-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    // Per-user Crossword stats (streaks, games played)
    match /users/{userId}/crossword-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Public Crossword player stats (cross-user readable for profile cards)
    match /crosswordPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Hero Guesser ──
    match /heroguesser-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/heroguesser-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /heroguesserPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Matchup Mania ──
    match /matchupmania-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/matchupmania-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /matchupmaniaPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Trivia ──
    match /trivia-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/trivia-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /triviaPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Timeline ──
    match /timeline-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/timeline-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /timelinePlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Connections ──
    match /connections-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/connections-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /connectionsPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Rhinar's Rampage ──
    match /rhinarsrampage-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/rhinarsrampage-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /rhinarsrampagePlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Kayo's Knockout ──
    match /kayosknockout-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/kayosknockout-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /kayosknockoutPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Brute Brawl ──
    match /brutebrawl-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/brutebrawl-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /brutebrawlPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Katsu's Combo (Ninja Combo) ──
    match /ninjacombo-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/ninjacombo-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /ninjacomboPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Shadow Strike ──
    match /shadowstrike-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/shadowstrike-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /shadowstrikePlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Blade Dash ──
    match /bladedash-results/{resultId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }
    match /users/{userId}/bladedash-stats/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /bladedashPlayerStats/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Sitemap Decklists (scraped from fabtcg.com, admin-only) ──
    match /sitemap-decklists/{docId} {
      allow read, write: if isAdmin();
    }
    match /sitemap-meta/{docId} {
      allow read, write: if isAdmin();
    }
    match /coverage-matches/{docId} {
      allow read, write: if isAdmin();
    }
    match /coverage-events/{docId} {
      allow read, write: if isAdmin();
    }
    match /coverage-matchup-summaries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Historical Events (auto-generated from scraped decklists) ──
    match /historical-events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin stats: any authed user can increment deletedAccounts (during account deletion)
    match /admin/stats {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /admin/{docId} {
      // Any authenticated user can read (needed for client-side admin check in isAdmin helper above)
      // Note: This exposes the admin email list to authenticated users. This is an accepted
      // tradeoff for client-side admin detection. The emails are not sensitive secrets.
      allow read: if request.auth != null;
      // Admins can write (for managing creators, etc.)
      allow write: if isAdmin();
    }

    match /admin/{docId}/{subcol}/{subDoc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Teams ──

    match /teams/{teamId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && maxLen(request.resource.data.name, 50)
        && request.resource.data.memberCount is int;
      allow update: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          || (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
              && get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role in ["owner", "admin"])
        )
        && (
          !('ownerUid' in request.resource.data.diff(resource.data).affectedKeys())
          || resource.data.ownerUid == request.auth.uid
        );
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /members/{memberId} {
        allow read: if true;
        // Team creator adds themselves as owner
        allow create: if request.auth != null
          && request.auth.uid == memberId
          && request.resource.data.role == "owner"
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        // Self-join on open teams
        allow create: if request.auth != null
          && request.auth.uid == memberId
          && request.resource.data.role == "member"
          && get(/databases/$(database)/documents/teams/$(teamId)).data.joinMode == "open";
        // Owner/admin can add members (invite acceptance)
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role in ["owner", "admin"];
        // Owner/admin can update roles (only owner can promote to owner for transfers)
        allow update: if request.auth != null
          && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role in ["owner", "admin"]
          && (
            request.resource.data.role in ["admin", "member"]
            || (request.resource.data.role == "owner"
                && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid)
          );
        // Self-leave or owner/admin kick
        allow delete: if request.auth != null
          && (request.auth.uid == memberId
              || (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
                  && get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role in ["owner", "admin"]));
      }
    }

    match /teamnames/{nameLower} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.teamId != null
        && get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.ownerUid == request.auth.uid;
    }

    match /teamInvites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.inviterUid == request.auth.uid
            || resource.data.targetUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.inviterUid == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && resource.data.targetUid == request.auth.uid
        && request.resource.data.status in ["accepted", "declined"];
      allow delete: if request.auth != null
        && (resource.data.inviterUid == request.auth.uid
            || resource.data.targetUid == request.auth.uid);
    }
  }
}
