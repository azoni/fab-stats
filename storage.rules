rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminConfig() {
      return firestore.get(/databases/(default)/documents/admin/config).data;
    }

    function adminEmails() {
      return ('adminEmails' in adminConfig() && adminConfig().adminEmails is list)
        ? adminConfig().adminEmails
        : [];
    }

    function adminUids() {
      return ('adminUids' in adminConfig() && adminConfig().adminUids is list)
        ? adminConfig().adminUids
        : [];
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || (request.auth.token.email != null && request.auth.token.email in adminEmails())
          || (request.auth.uid != null && request.auth.uid in adminUids())
        );
    }

    function validBackgroundFileName(fileName) {
      return fileName.matches('^[A-Za-z0-9._-]+\\.(jpg|jpeg|png|webp)$');
    }

    function validImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp)')
        && request.resource.size <= maxBytes;
    }

    // Public read for profile backgrounds (site visitors can load these images).
    // Writes are admin-only and constrained by path + content limits.
    match /profile-backgrounds/full/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && (
          request.resource == null
          || (validBackgroundFileName(fileName) && validImageUpload(8 * 1024 * 1024))
        );
    }

    match /profile-backgrounds/thumb/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && (
          request.resource == null
          || (validBackgroundFileName(fileName) && validImageUpload(800 * 1024))
        );
    }

    match /profile-backgrounds/{allPaths=**} {
      allow read, write: if false;
    }

    // Team icons: public read, authenticated write with size limits
    match /team-images/icons/{teamId}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && (
          request.resource == null
          || validImageUpload(2 * 1024 * 1024)
        );
    }

    // Team share card backgrounds: public read, authenticated write with size limits
    match /team-images/backgrounds/{teamId}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && (
          request.resource == null
          || validImageUpload(8 * 1024 * 1024)
        );
    }

    // Default deny for everything else in Storage.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
